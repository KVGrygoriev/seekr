# Postgres (used by docker-compose and the app)
POSTGRES_USER=seekr
POSTGRES_PASSWORD=change_me
POSTGRES_DB=seekr
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full async DB URL (built from the above for local runs; override if needed)
SEEKR_DATABASE_URL=postgresql+asyncpg://seekr:change_me@postgres:5432/seekr

# Telegram bot — get a token from @BotFather and your chat id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Path to the YAML config inside the container
SEEKR_CONFIG_PATH=/app/config/seekr.yaml

# Log level: DEBUG, INFO, WARNING, ERROR
SEEKR_LOG_LEVEL=INFO
